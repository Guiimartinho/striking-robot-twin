<!-- Single-DOF Series Elastic striker arm (Phase 0 test arm).

  Two stages in series, the essence of an SEA:
    motor_y  : actuated slide, the BLDC + transmission position (commanded)
    spring_y : passive slide with stiffness, the series spring (compliant)
  The link force is sensed from spring deflection: F = jnt_stiffness * qpos(spring_y).
  The spring is the passive energy limiter AND the force sensor, exactly as on the
  real drive, so the control code above the HAL is born compatible.

  Geometry is a reasonable default (CLAUDE.md section 11): tune later. The arm
  base sits at (0, 0, 1.0), body height, and punches along +y toward the trainee.
  It is deliberately at body height, not head height: the 1-DOF arm moves only in
  +y at a fixed z, so its whole reachable path must stay clear of the head/neck
  keep-out. At z=1.0 that path is well below the head, so what the SafetyArbiter
  approves matches what the arm actually executes. -->
<mujoco model="striker_arm">
  <worldbody>
    <body name="arm_base" pos="0 0 1.0">
      <geom name="arm_mount" type="box" size="0.05 0.05 0.05" rgba="0.30 0.30 0.35 1" mass="2"/>

      <!-- Motor stage: position-controlled slide along the punch axis. -->
      <body name="motor" pos="0 0 0">
        <joint name="motor_y" type="slide" axis="0 1 0" range="0 0.8" damping="2.0"/>
        <geom name="motor_geom" type="cylinder" fromto="0 0 0 0 0.10 0" size="0.03"
              rgba="0.40 0.40 0.45 1" mass="1.5"/>

        <!-- Series elastic stage: the spring between motor and link. Its
             deflection (qpos) times stiffness is the sensed strike force. -->
        <body name="forearm" pos="0 0.10 0">
          <joint name="spring_y" type="slide" axis="0 1 0" range="-0.05 0.05"
                 stiffness="3000" damping="20" springref="0"/>
          <geom name="forearm_geom" type="capsule" fromto="0 0 0 0 0.25 0" size="0.035"
                rgba="0.50 0.50 0.55 1" mass="1.0"/>

          <!-- Padded glove. Soft contact (compliant solref) keeps impacts low
               energy; on the real robot this is foam over the end effector. -->
          <body name="glove" pos="0 0.25 0">
            <geom name="glove_geom" type="sphere" size="0.06" rgba="0.80 0.20 0.20 1"
                  mass="0.4" solref="0.02 1" solimp="0.9 0.95 0.001"/>
            <site name="glove_tip" pos="0 0.06 0" size="0.01" rgba="1 1 0 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Commands the motor stage position. The series spring decouples this
         from the contact force, which is the whole point of an SEA. -->
    <position name="motor_y_act" joint="motor_y" kp="500" ctrlrange="0 0.8"/>
  </actuator>

  <sensor>
    <jointpos name="spring_y_pos" joint="spring_y"/>
  </sensor>
</mujoco>
