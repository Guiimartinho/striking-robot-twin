<!-- Boxing scene built on the Unitree G1 (fetched into assets/unitree_g1 by
  scripts/fetch_g1.py; included here by relative path). Adds a floor, a heavy bag
  and offscreen render size. The robot is a stationary striker: for kinematic
  combo rendering the base qpos is held at the "stand" keyframe each frame, so it
  does not fall. The safety/drill logic above the HAL is unchanged.
  fetch_g1.py copies this scene next to g1.xml so its meshdir resolves. -->
<mujoco model="g1_boxer scene">
  <include file="g1.xml"/>

  <statistic center="0.2 0 1.0" extent="1.2"/>

  <visual>
    <headlight diffuse="0.65 0.65 0.65" ambient="0.18 0.18 0.18" specular="0.3 0.3 0.3"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-14" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.25 0.35 0.5" rgb2="0.02 0.04 0.08"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.18 0.22 0.28"
             rgb2="0.1 0.14 0.18" markrgb="0.7 0.7 0.7" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
              reflectance="0.15"/>
    <material name="bag" rgba="0.18 0.18 0.21 1"/>
  </asset>

  <worldbody>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <body name="bag" pos="0.42 0 1.05" mocap="true">
      <geom name="bag_geom" type="capsule" fromto="0 0 -0.42 0 0 0.42" size="0.12" material="bag"
            mass="35"/>
    </body>
  </worldbody>
</mujoco>
