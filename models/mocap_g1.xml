<!-- Clean playback scene for motion-capture clips on the Unitree G1.

  The G1 model is fetched (not vendored in git) by scripts/fetch_g1.py, which
  also copies this scene next to g1.xml in assets/unitree_g1 so the model's
  meshdir resolves. Floor + skybox + offscreen size, no bag: the retargeted fight
  clip moves the root freely, so the camera tracks the pelvis and there is
  nothing for the footwork to clip into. -->
<mujoco model="g1_mocap scene">
  <include file="g1.xml"/>

  <statistic center="0 0 1.0" extent="1.4"/>

  <visual>
    <headlight diffuse="0.65 0.65 0.65" ambient="0.18 0.18 0.18" specular="0.3 0.3 0.3"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-14" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.25 0.35 0.5" rgb2="0.02 0.04 0.08"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.18 0.22 0.28"
             rgb2="0.1 0.14 0.18" markrgb="0.7 0.7 0.7" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
              reflectance="0.15"/>
  </asset>

  <worldbody>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  </worldbody>
</mujoco>
