<!-- Trainee upper-body mannequin (Phase 0).

  Static (welded to world) for Phase 0: the ground-truth pose comes from the
  keypoint sites below, and dynamic motion (dodging, lunging) is injected by the
  fault harness, not physics, at this stage. Articulation arrives in later phases.

  The kp_* sites ARE the ground-truth keypoints the SimGTObserver reads, named to
  match the Keypoint enum in core.types. Lower body is intentionally absent (the
  punches-only, upper-body MVP). The hands sit high, near the face: a guard. -->
<mujoco model="trainee">
  <worldbody>
    <body name="trainee" pos="0 0 0">
      <!-- Visual body, facing -y toward the robot. -->
      <geom name="torso_geom" type="box" pos="0 0.73 1.25" size="0.16 0.09 0.18"
            rgba="0.20 0.40 0.70 1"/>
      <geom name="head_geom" type="sphere" pos="0 0.75 1.62" size="0.10"
            rgba="0.90 0.70 0.60 1"/>
      <geom name="neck_geom" type="capsule" fromto="0 0.75 1.45 0 0.75 1.52" size="0.04"
            rgba="0.90 0.70 0.60 1"/>
      <geom name="l_upper_arm" type="capsule" fromto="0.18 0.73 1.40 0.22 0.78 1.15"
            size="0.04" rgba="0.20 0.40 0.70 1"/>
      <geom name="r_upper_arm" type="capsule" fromto="-0.18 0.73 1.40 -0.22 0.78 1.15"
            size="0.04" rgba="0.20 0.40 0.70 1"/>
      <geom name="l_forearm" type="capsule" fromto="0.22 0.78 1.15 0.12 0.62 1.50"
            size="0.035" rgba="0.20 0.40 0.70 1"/>
      <geom name="r_forearm" type="capsule" fromto="-0.22 0.78 1.15 -0.12 0.62 1.50"
            size="0.035" rgba="0.20 0.40 0.70 1"/>

      <!-- Ground-truth keypoints. Order and names mirror core.types.Keypoint. -->
      <site name="kp_head" pos="0 0.75 1.62" size="0.02" rgba="1 0 0 0.6"/>
      <site name="kp_neck" pos="0 0.75 1.45" size="0.02" rgba="1 0.5 0 0.6"/>
      <site name="kp_chest" pos="0 0.72 1.25" size="0.02" rgba="1 1 0 0.6"/>
      <site name="kp_l_shoulder" pos="0.18 0.73 1.40" size="0.02" rgba="0 1 0 0.6"/>
      <site name="kp_r_shoulder" pos="-0.18 0.73 1.40" size="0.02" rgba="0 1 0 0.6"/>
      <site name="kp_l_elbow" pos="0.22 0.78 1.15" size="0.02" rgba="0 1 1 0.6"/>
      <site name="kp_r_elbow" pos="-0.22 0.78 1.15" size="0.02" rgba="0 1 1 0.6"/>
      <site name="kp_l_hand" pos="0.12 0.62 1.50" size="0.02" rgba="0 0 1 0.6"/>
      <site name="kp_r_hand" pos="-0.12 0.62 1.50" size="0.02" rgba="0 0 1 0.6"/>
    </body>
  </worldbody>
</mujoco>
